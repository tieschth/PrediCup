# Скопируй в .env и заполни своими значениями
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
FOOTBALL_API_KEY=your_football_data_org_api_key
# prod | dev  (dev включает /devmatch и /devresult)
ENV=dev
# Путь к конфигу и БД (можно не менять)
CONFIG_PATH=config/config.yaml
DB_PATH=data/predicup.sqlite3

# Прокси ТОЛЬКО для Telegram — заполнять, если api.telegram.org недоступен
# напрямую (например, с сервера в РФ). Пусто = без прокси.
# Примеры: http://user:pass@host:port  или  socks5://user:pass@host:port
TELEGRAM_PROXY=
